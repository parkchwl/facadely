# Backend API
# Local:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# INTERNAL_API_BASE_URL=http://localhost:8080/api/v1
# Railway backend example:
# NEXT_PUBLIC_API_BASE_URL=https://backend-production-b5b9c.up.railway.app/api/v1
# INTERNAL_API_BASE_URL=https://backend-production-b5b9c.up.railway.app/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
INTERNAL_API_BASE_URL=http://localhost:8080/api/v1

# Site URL
# For local development, use http://localhost:3000
# For production, use your actual domain (e.g., https://facadely.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Editor entry
NEXT_PUBLIC_BETA_EDITOR_URL=/editor

# Dangerous internal dev tool. Keep disabled unless you explicitly need runtime page code generation.
FACADELY_ENABLE_TEMPLATE_CODEGEN=false
