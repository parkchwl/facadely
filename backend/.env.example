# Copy this file to backend/.env
# Spring Boot loads backend/.env automatically via spring.config.import

# Backend
SERVER_PORT=8080
FRONTEND_ORIGIN=http://localhost:3000
DEFAULT_LOCALE=en

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/facadely
SPRING_DATASOURCE_USERNAME=facadely
SPRING_DATASOURCE_PASSWORD=facadely

# JWT
# Replace both secrets before using any non-local environment.
JWT_ACCESS_SECRET=change-this-access-secret-change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret-change-this-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# Cookies
# Keep COOKIE_SECURE=false only for local http development.
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_ACCESS_NAME=facadely_at
COOKIE_REFRESH_NAME=facadely_rt

# Terms Versioning
TERMS_VERSION=2026-01
PRIVACY_VERSION=2026-01

# Google OAuth
# Replace these values before enabling Google login outside local development.
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
