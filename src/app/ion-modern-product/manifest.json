    { "editId": "t2-cta-secondary", "label": "Secondary CTA", "kind": "button", "fields": ["text", "button", "color", "font"] },
    { "editId": "t2-features-title", "label": "Features Title", "kind": "text", "fields": ["text", "color", "font"] },
    { "editId": "t2-performance-title", "label": "Performance Title", "kind": "text", "fields": ["text", "color", "font"] },
    { "editId": "t2-system-title", "label": "System Title", "kind": "text", "fields": ["text", "color", "font"] }
